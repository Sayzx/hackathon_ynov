# Phi-3.5-Financial Infrastructure Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_NUM_PARALLEL=4
OLLAMA_NUM_THREAD=8

# Model Configuration
MODEL_NAME=phi-financial
MODEL_BASE=phi3.5
MODEL_TIMEOUT=300

# Container Configuration
DOCKER_IMAGE=ollama/ollama:latest
CONTAINER_NAME=phi-financial-ollama
RESTART_POLICY=unless-stopped

# Volume Configuration
VOLUME_NAME=ollama_data
VOLUME_DRIVER=local

# Network Configuration
NETWORK_NAME=phi-financial
NETWORK_DRIVER=bridge

# Logging Configuration
LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# Project Configuration
PROJECT_DIR=/opt/phi-financial
PROJECT_NAME=phi-financial
